---
// Header.astro
const navLinks = [
  { name: 'Programme', href: '/programme' },
  { name: 'Artistes', href: '/artistes' },
  { name: 'Scènes', href: '/scenes' },
  { name: 'Le Festival', href: '/festival' },
  { name: 'Infos pratiques', href: '/infos' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="header bg-noir sticky top-0 z-1000">
  <nav class="header__nav flex items-center justify-between px-6 py-4 lg:px-12 max-w-360 mx-auto relative">
    
    <a href="/" class="header__logo flex items-center gap-3 no-underline">
      <img src="/logo.png" alt="Logo" class="w-8 h-8 object-contain" />
      <h1 class="header__site-title text-or-profond font-serif text-xl font-bold m-0 leading-none">
        Chorus Symphonia
      </h1>
    </a>

    <button 
      id="menu-toggle" 
      class="header__menu-toggle flex flex-col justify-center items-center gap-1.5 w-8 h-8 bg-none border-none cursor-pointer lg:hidden z-50"
      aria-label="Ouvrir le menu"
    >
      <span class="header__menu-line w-6 h-0.5 bg-or-profond transition-all duration-300"></span>
      <span class="header__menu-line w-6 h-0.5 bg-or-profond transition-all duration-300"></span>
      <span class="header__menu-line w-6 h-0.5 bg-or-profond transition-all duration-300"></span>
    </button>

    <ul 
      id="nav-list" 
      class="header__nav-list 
             /* Mobile : Menu plein écran qui descend */
             fixed top-16 left-0 w-full bg-noir flex flex-col items-center
             max-h-0 overflow-hidden transition-all duration-500 ease-in-out z-40
             /* Desktop : Menu horizontal classique */
             lg:static lg:flex-row lg:max-h-none lg:w-auto lg:overflow-visible lg:gap-8 lg:bg-transparent"
    >
      {navLinks.map((link) => (
        <li class="w-full lg:w-auto border-b border-ivoir/10 lg:border-none last:border-none">
          <a 
            href={link.href} 
            class="header__nav-link block py-6 lg:py-0 text-center text-or-profond text-lg lg:text-sm uppercase tracking-[0.2em] font-medium hover:opacity-70 transition-opacity"
          >
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  /* --- ÉTAT ACTIF MOBILE --- */
  
  /* Déroulement du menu */
  #nav-list.active {
    max-height: 100vh;
    padding-bottom: 2rem;
  }

  /* Transformation en X de l'icône */
  #menu-toggle.active .header__menu-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  #menu-toggle.active .header__menu-line:nth-child(2) {
    opacity: 0;
    transform: translateX(-20px);
  }

  #menu-toggle.active .header__menu-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* --- DESKTOP HOVER EFFECT --- */
  @media (min-width: 1024px) {
    .header__nav-link {
      position: relative;
    }
    .header__nav-link::after {
      content: "";
      position: absolute;
      bottom: -6px;
      left: 50%;
      width: 0;
      height: 1px;
      background-color: var(--color-or-profond);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }
    .header__nav-link:hover::after {
      width: 100%;
    }
  }
</style>

<script>
  const initMenu = () => {
    const btn = document.getElementById('menu-toggle');
    const nav = document.getElementById('nav-list');
    
    // Fermer le menu si on clique sur un lien (mobile)
    const links = document.querySelectorAll('.header__nav-link');

    if (btn && nav) {
      btn.addEventListener('click', () => {
        btn.classList.toggle('active');
        nav.classList.toggle('active');
        
        // Empêcher le scroll du body quand le menu est ouvert
        document.body.style.overflow = nav.classList.contains('active') ? 'hidden' : '';
      });

      links.forEach(link => {
        link.addEventListener('click', () => {
          btn.classList.remove('active');
          nav.classList.remove('active');
          document.body.style.overflow = '';
        });
      });
    }
  };

  // Initialisation au chargement et entre les pages Astro
  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>