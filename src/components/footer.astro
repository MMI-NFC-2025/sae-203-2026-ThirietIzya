---
// Footer.astro
---

<footer class="bg-noir text-ivoir py-16 font-[--font-family]">
  <div class="grille gap-y-12 items-start">
    
    <div class="lg:col-span-4 flex flex-col gap-8">
      <div>
        <h2 class="text-or-profond text-3xl font-serif tracking-wide !my-0 mb-4">
          Chorus Symphonia
        </h2>
        <p class="text-sm leading-relaxed max-w-[300px] opacity-80">
          Le rendez-vous incontournable de la musique classique à Paris depuis 1998.
        </p>
      </div>

      <div class="flex flex-col gap-3">
        <h3 class="text-ivoir text-sm font-bold uppercase tracking-widest !my-0">Contact</h3>
        <ul class="flex flex-col gap-2 text-sm opacity-90">
          <li>+33 1 23 45 67 89</li>
          <li><a href="mailto:contact@chorussymphonia.fr" class="hover:text-or-profond transition-colors">contact@chorussymphonia.fr</a></li>
          <li class="mt-2">Opéra National<br/>8 Rue Scribe, 75009 Paris</li>
        </ul>
      </div>
    </div>

    <div class="lg:col-span-2 flex flex-col gap-6">
      <h3 class="text-ivoir text-sm font-bold uppercase tracking-widest !my-0">Liens rapides</h3>
      <ul class="flex flex-col gap-3 text-sm opacity-90">
        <li><a href="#" class="hover:text-or-profond transition-colors">Accueil</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Le Festival</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Programme</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Artistes</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Scènes</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Infos pratiques</a></li>
        <li><a href="#" class="hover:text-or-profond transition-colors">Contact</a></li>
      </ul>
    </div>

    <div class="lg:col-span-3 flex flex-col gap-6">
      <h3 class="text-ivoir text-sm font-bold uppercase tracking-widest !my-0">Suivez-nous</h3>
      <div class="flex gap-4">
        <a href="#" class="hover:text-or-profond transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" class="hover:text-or-profond transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
        </a>
        <a href="#" class="hover:text-or-profond transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </a>
        <a href="#" class="hover:text-or-profond transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 2-2 69.44 69.44 0 0 1 15 0 2 2 0 0 1 2 2 24.12 24.12 0 0 1 0 10 2 2 0 0 1-2 2 69.44 69.44 0 0 1-15 0 2 2 0 0 1-2-2Z"></path><path d="m9.75 15.02 5.75-3.02-5.75-3.02Z"></path></svg>
        </a>
      </div>
    </div>

    <div class="lg:col-span-3 flex flex-col gap-6">
      <h3 class="text-ivoir text-sm font-bold uppercase tracking-widest !my-0">Newsletter</h3>
      <form class="flex items-center gap-3">
        <input 
          type="email" 
          placeholder="Votre email" 
          class="bg-ivoir text-noir/60 px-4 py-3 rounded-lg w-full text-sm outline-none"
        />
        <button 
          type="submit" 
          class="bg-or-profond text-noir px-6 py-3 rounded-lg font-bold text-sm uppercase transition hover:brightness-110"
        >
          OK
        </button>
      </form>
    </div>

    <div class="lg:col-span-12 border-t border-ivoir/20 pt-10 mt-8">
      <div class="flex flex-col lg:flex-row justify-between items-center gap-6 text-sm opacity-90">
        <p>© 2025 Chorus Symphonia. Tous droits réservés.</p>
        <div class="flex gap-8">
          <a href="#" class="hover:text-or-profond transition-colors">Politique de confidentialité</a>
          <a href="#" class="hover:text-or-profond transition-colors">CGV</a>
          <a href="#" class="hover:text-or-profond transition-colors">Mentions légales</a>
        </div>
      </div>
    </div>

  </div>
</footer>