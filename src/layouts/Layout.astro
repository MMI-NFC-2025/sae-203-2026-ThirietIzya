---
import '../styles/global.css';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Chorus Symphonia 2025 | Festival de Musique Classique à Paris",
	description = "Découvrez le Festival Chorus Symphonia 2025, une célébration exceptionnelle de la musique classique du 15 au 22 juin à Paris."
} = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<Header />
		<main class="flex-1 pt-20">
			<slot />
		</main>
		<Footer />
	</body>
</html>
