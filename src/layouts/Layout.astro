---
// 1. IMPORTATION DU CSS (Vérifie bien le chemin vers ton fichier .css)
import '../styles/global.css'; 

import Header from '../components/header.astro';
import Footer from '../components/footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Chorus Symphonia</title>
	</head>
	<body class="bg-[--ivoir] text-[--noir]">
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>