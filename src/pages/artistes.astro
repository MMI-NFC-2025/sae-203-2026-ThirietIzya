---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { artistesSorted } from '../../backend/backend.mjs';

import heroImg from '../assets/img/hero_artiste.webp';

// helper to build an URL for a file stored in PocketBase
function getFileUrl(record: any, field: string) {
  if (!record || !record[field]) return '';
  return `http://127.0.0.1:8090/api/files/${record.collectionId}/${record.id}/${record[field]}`;
}

// fetch the list from PocketBase; this runs at build time / server-side
const pbRecords = await artistesSorted();

// convert PocketBase objects into a shape our component expects
const artistes = pbRecords.map((r: any) => {
  const name = `${r.prenom_artiste || ''} ${r.nom_artiste || ''}`.trim();
  const role = r.genre_musical || '';
  const description = r.description || '';
  const perf = r.date_representation
    ? new Date(r.date_representation).toLocaleDateString('fr-FR', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      })
    : '';
  return {
    id: r.id,
    name,
    role,
    imageUrl: getFileUrl(r, 'photo_principale'),
    description,
    perf,
  };
});
---

<Layout title="Artistes">
  <section class="relative h-[50vh] flex items-center justify-center text-center overflow-hidden">
    <Image
      src={heroImg}
      alt="Artistes de musique classique sur scène"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-noir/65"></div>
    <div class="relative z-10 px-6">
      <h1 class="text-ivoir text-3xl lg:text-5xl font-serif italic leading-tight">Artistes</h1>
      <p class="text-ivoir/80 mt-2">Rencontrez les artistes exceptionnels qui feront vibrer le festival</p>
    </div>
  </section>

  <section class="bg-ivoir py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {artistes.map((a) => (
          <article class="bg-white rounded-xl shadow-sm overflow-hidden flex flex-col group">
            <div class="aspect-4/5 overflow-hidden">
              <img src={a.imageUrl} alt={a.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-serif text-2xl italic text-noir mb-1">{a.name}</h3>
              <p class="text-or-profond uppercase tracking-widest text-[10px] font-bold mb-4">{a.role}</p>
              <p class="text-sm text-gris-claire flex-1 mb-6">{a.description}</p>
              <a
                href={`/artiste/${a.id}`}
                class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/40 pb-1 hover:border-or-profond w-fit"
              >
                En savoir plus →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
