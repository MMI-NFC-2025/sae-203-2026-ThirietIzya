---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/img/hero_festival.webp';
import cardFestival from '../assets/img/card_festival.webp';

const stats = [
  { number: "27 ans", label: "d'histoire" },
  { number: "250+", label: "artistes accueillis" },
  { number: "400 000+", label: "spectateurs" }
];

const values = [
  {
    title: "Excellence Artistique",
    description: "Proposer une programmation de qualité exceptionnelle avec les meilleurs artistes internationaux.",
    icon: "music"
  },
  {
    title: "Accessibilité",
    description: "Rendre la musique classique accessible à tous les publics, des mélomanes aux néophytes.",
    icon: "heart"
  },
  {
    title: "Transmission",
    description: "Favoriser la découverte et l'apprentissage de la musique classique auprès des jeunes générations.",
    icon: "users"
  },
  {
    title: "Innovation",
    description: "Proposer des formats innovants tout en respectant les traditions du répertoire classique.",
    icon: "plus"
  }
];

const team = [
  { name: "Élisabeth Rousseau", role: "Directrice Artistique", desc: "Passionnée de musique classique depuis l'enfance, elle dirige le festival depuis sa création." },
  { name: "Marc Fontaine", role: "Directeur Général", desc: "Expert en gestion culturelle, il assure la coordination de l'ensemble du festival." },
  { name: "Claire Dubois", role: "Responsable Programmation", desc: "Violoniste de formation, elle sélectionne les artistes et compose le programme." },
  { name: "Antoine Martin", role: "Responsable Communication", desc: "Spécialiste du marketing culturel, il assure la visibilité du festival." }
];
---

<Layout title="Le Festival | Chorus Symphonia 2025">
  
  <section class="relative h-[60vh] flex items-center justify-center text-center text-ivoir overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image src={heroImg} alt="Coulisses du festival" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-noir/60"></div>
    </div>
    <div class="relative z-10 px-6">
      <p class="text-or-profond uppercase tracking-[0.4em] mb-4 text-xs font-bold">Le Festival</p>
      <h1 class="text-3xl lg:text-5xl font-serif italic leading-tight max-w-3xl mx-auto">
        27 ans de passion pour la musique classique
      </h1>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="font-serif text-3xl lg:text-4xl italic mb-12 text-noir text-center">Notre Histoire</h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="rounded-xl overflow-hidden shadow-lg">
          <Image src={cardFestival} alt="Le festival Chorus Symphonia" class="w-full h-full object-cover" />
        </div>
        <div class="space-y-8 text-gris-claire leading-relaxed font-light text-lg">
          <p>
            Fondé en 1998, le Festival Chorus Symphonia est né de la volonté de créer un événement culturel d'envergure internationale à Paris, célébrant le patrimoine musical classique tout en offrant une scène aux talents contemporains.
          </p>
          <p>
            Au fil des années, le festival s'est imposé comme un rendez-vous incontournable pour les amateurs de musique classique. Chaque édition rassemble plus de 15 000 spectateurs venus du monde entier pour découvrir ou redécouvrir les plus belles œuvres du répertoire.
          </p>
          <p>
            Grâce à la qualité de sa programmation et à l'excellence de son organisation, Chorus Symphonia a accueilli les plus grands orchestres et solistes internationaux, créant des moments inoubliables.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-24 border-t border-or-profond/20 pt-16">
        {stats.map(stat => (
          <div class="flex flex-col items-center">
            <span class="text-or-profond font-serif text-4xl lg:text-5xl mb-2 italic">{stat.number}</span>
            <span class="text-gris-claire uppercase tracking-widest text-[10px] font-bold">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-20 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-serif text-3xl lg:text-4xl italic text-center mb-20 text-noir">Nos Valeurs</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map(value => (
          <div class="bg-white border border-noir/5 p-10 shadow-sm hover:shadow-md transition-shadow text-center flex flex-col items-center group">
            <div class="w-16 h-16 rounded-full bg-ivoir flex items-center justify-center text-or-profond mb-6 group-hover:bg-or-profond group-hover:text-ivoir transition-colors duration-500">
              {value.icon === 'music' && <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>}
              {value.icon === 'heart' && <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"></path></svg>}
              {value.icon === 'users' && <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 00-3-3.87"></path><path d="M16 3.13a4 4 0 010 7.75"></path></svg>}
              {value.icon === 'plus' && <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 2v20M2 12h20"></path><circle cx="12" cy="12" r="10"></circle></svg>}
            </div>
            <h3 class="font-serif text-xl mb-4 italic text-noir">{value.title}</h3>
            <p class="text-sm text-gris-claire font-light leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="font-serif text-3xl lg:text-4xl italic text-center mb-20 text-noir">Notre Équipe</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        {team.map(member => (
          <div class="flex flex-col items-center text-center">
            <div class="w-32 h-32 rounded-full bg-linear-to-tr from-or-profond to-doré-clair p-0.5 mb-6 shadow-lg">
              <div class="w-full h-full rounded-full bg-white flex items-center justify-center text-or-profond">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
            </div>
            <h3 class="font-serif text-xl italic text-noir mb-1">{member.name}</h3>
            <p class="text-or-profond uppercase tracking-widest text-[10px] font-bold mb-4">{member.role}</p>
            <p class="text-xs text-gris-claire leading-relaxed font-light">{member.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>