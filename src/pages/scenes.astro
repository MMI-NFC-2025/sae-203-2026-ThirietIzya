---
import Layout from '../layouts/Layout.astro';

const scenes = [
  {
    nom: "Opéra National de Paris - Grande Salle",
    adresse: "Place de l'Opéra, 75009 Paris",
    places: "2200 places",
    description: "La salle principale de l'Opéra National de Paris, connue mondialement pour son acoustique exceptionnelle et son architecture majestueuse.",
    acces: "Métro Opéra (lignes 3, 7, 8), RER A Auber",
    featured: true
  },
  {
    nom: "Salle Garnier",
    adresse: "15 Avenue Montaigne, 75008 Paris",
    places: "600 places",
    description: "Une salle intimiste parfaite pour les récitals et la musique de chambre.",
    acces: "Métro Alma-Marceau (ligne 9), RER C Pont de l'Alma",
    featured: false
  },
  {
    nom: "Salon des Glaces",
    adresse: "252 Rue du Faubourg Saint-Honoré, 75008 Paris",
    places: "150 places",
    description: "Un lieu d'exception pour des concerts intimistes dans un cadre historique remarquable.",
    acces: "Métro Ternes (ligne 2), Charles de Gaulle-Étoile (lignes 1, 2, 6, RER A)",
    featured: false
  }
];
---

<Layout title="Scènes | Chorus Symphonia 2025" description="Découvrez les trois salles prestigieuses au coeur de Paris qui accueilleront le Festival Chorus Symphonia 2025.">
  <!-- Hero -->
  <section class="py-20 md:py-32 bg-gradient-to-b from-primary-light to-primary">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Les lieux</p>
      <h1 class="text-white mb-6">Nos Scènes</h1>
      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        Trois salles prestigieuses au coeur de Paris
      </p>
    </div>
  </section>

  <!-- Scènes -->
  <section class="py-20 md:py-32 bg-primary">
    <div class="max-w-5xl mx-auto px-6">
      <div class="space-y-12">
        {scenes.map((scene, index) => (
          <article class={`card p-8 md:p-10 ${scene.featured ? 'border-gold/30 bg-gradient-to-br from-primary-light to-primary' : ''}`}>
            <div class="flex flex-col lg:flex-row gap-8">
              <!-- Image placeholder -->
              <div class="lg:w-2/5 flex-shrink-0">
                <div class="aspect-video lg:aspect-square rounded-xl bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-gold/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>
              </div>
              
              <!-- Content -->
              <div class="flex-1">
                <h2 class="text-white text-2xl md:text-3xl font-serif mb-4">{scene.nom}</h2>
                
                <div class="space-y-3 mb-6">
                  <p class="text-white/60 flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span>{scene.adresse}</span>
                  </p>
                  <p class="text-white/60 flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                    <span class="text-gold font-medium">{scene.places}</span>
                  </p>
                </div>
                
                <p class="text-white/70 mb-6 leading-relaxed">
                  {scene.description}
                </p>
                
                <div class="p-4 bg-white/5 rounded-lg mb-6">
                  <p class="text-sm text-white/60">
                    <span class="text-gold font-medium">Accès :</span> {scene.acces}
                  </p>
                </div>
                
                <a href="#" class="text-gold font-medium flex items-center gap-2 hover:gap-3 transition-all">
                  En savoir plus
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-20 bg-primary-light">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="text-white mb-4">Comment venir</h2>
        <p class="text-white/60 max-w-2xl mx-auto">
          Toutes nos salles sont accessibles en transports en commun et disposent de parkings à proximité.
        </p>
      </div>
      
      <div class="card p-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </div>
            <h3 class="text-white mb-2">Métro</h3>
            <p class="text-white/60 text-sm">Lignes 1, 2, 3, 6, 7, 8, 9</p>
          </div>
          
          <div class="text-center">
            <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
              </svg>
            </div>
            <h3 class="text-white mb-2">RER</h3>
            <p class="text-white/60 text-sm">RER A - Auber, Étoile</p>
          </div>
          
          <div class="text-center">
            <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center mx-auto mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
            </div>
            <h3 class="text-white mb-2">Parking</h3>
            <p class="text-white/60 text-sm">Parkings à proximité</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
