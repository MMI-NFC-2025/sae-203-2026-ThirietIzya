---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// static hero
import heroImg from '../assets/img/hero_scenes.webp';

// icons used in cards
import mapIcon from '../assets/icon/map_dore_petit.svg';
import equipeIcon from '../assets/icon/equipe_dore_petit.svg';

import { scenesName } from '../../backend/backend.mjs';

// helper to build a PocketBase file URL
function getFileUrl(record: any, field: string) {
  if (!record || !record[field]) return '';
  return `https://chorussymphonia.thiriet.optimiseus.fr:443/api/files/${record.collectionId}/${record.id}/${record[field]}`;
}

interface Scene {
  id?: string;
  name: string;
  imageUrl: string;
  address: string;
  capacity: string;
  description: string;
  access: string;
  concerts?: string;
}

const pbScenes = await scenesName();
const scenes: Scene[] = pbScenes.map((r: any) => ({
  id: r.id,
  name: `${r.nom_scene}`,
  imageUrl: getFileUrl(r, 'photo_scene'),
  address: r.localisation || '',
  capacity: r.capacite ? `${r.capacite} places` : '',
  description: r.description_scene || '',
  access: r.localisation || '',
  concerts: r.Concerts?.length ? `${r.Concerts.length} concerts` : undefined,
}));
---

<Layout title="Scènes">
  <section class="relative h-[50vh] flex items-center justify-center text-center overflow-hidden">
    <Image
      src={heroImg}
      alt="Salle de concert prestigieuse à Paris"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-noir/65"></div>
    <div class="relative z-10 px-6">
      <h1 class="text-ivoir text-3xl lg:text-5xl font-serif italic leading-tight">Nos Scènes</h1>
      <p class="text-ivoir/80 mt-2">Trois salles prestigieuses au cœur de Paris</p>
    </div>
  </section>

  <section class="bg-ivoir py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {scenes.map((s) => (
          <article class="relative bg-white rounded-xl shadow-sm overflow-hidden flex flex-col group">
            <div class="relative aspect-video overflow-hidden">
              <img
                src={s.imageUrl}
                alt={s.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              {s.concerts && (
                <span class="absolute top-3 right-3 bg-or-profond text-noir text-xs px-2 py-1 rounded-full">
                  {s.concerts}
                </span>
              )}
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="font-serif text-2xl italic text-noir mb-1">{s.name}</h3>
              <div class="flex flex-wrap text-sm text-gris-claire gap-4 mb-4">
                <div class="flex items-center gap-2">
                  <Image src={mapIcon} alt="" class="w-4 h-4" />
                  <span>{s.address}</span>
                </div>
                <div class="flex items-center gap-2">
                  <Image src={equipeIcon} alt="" class="w-4 h-4" />
                  <span>{s.capacity}</span>
                </div>
              </div>
              <p class="text-sm text-gris-claire flex-1 mb-4">{s.description}</p>
              <p class="text-sm mb-4">
                <strong>Accès&nbsp;:</strong> {s.access}
              </p>
              <a
                href={`/scene/${s.id}`}
                class="mt-auto text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/40 pb-1 hover:border-or-profond w-fit"
              >
                En savoir plus →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
