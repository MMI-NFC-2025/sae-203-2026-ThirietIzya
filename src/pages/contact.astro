---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { contactsList } from '../../backend/backend.mjs';

// hero image
import heroImg from '../assets/img/hero_accueil.webp';

// icons
import phoneIcon from '../assets/icon/telephone_dore.svg';
import mailIcon from '../assets/icon/mail_dore.svg';
import mapIcon from '../assets/icon/map_dore.svg';
import facebookIcon from '../assets/icon/facebook_dore.svg';
import twitterIcon from '../assets/icon/twitter_dore.svg';
import instagramIcon from '../assets/icon/instagram_dore.svg';
import youtubeIcon from '../assets/icon/youtube_dore.svg';

// fetch contact records from PocketBase
const pbContacts = await contactsList();
const contactData = pbContacts[0] || {}; // we'll just use first record for now

// extract handy fields with defaults
const address = contactData.adresse || '15 Rue de la Paix\n75002 Paris\nFrance';
const phoneStandard = contactData.telephone_standard || '01 42 33 44 55';
const phoneBilletterie = contactData.telephone_billetterie || '01 42 33 44 56';
const emailGeneral = contactData.email_general || 'contact@chorussymphonia.fr';
const emailBilletterie = contactData.email_billetterie || 'billetterie@chorussymphonia.fr';
const emailPresse = contactData.email_presse || 'presse@chorussymphonia.fr';
const emailPartenariat = contactData.email_partenariats || 'partenariats@chorussymphonia.fr';

// form fields could come from PB later
---

<Layout title="Contact">
  <!-- hero -->
  <section class="relative h-[50vh] flex items-center justify-center text-center overflow-hidden">
    <Image
      src={heroImg}
      alt="Nous contacter"
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-noir/65"></div>
    <div class="relative z-10 px-6">
      <h1 class="text-ivoir text-3xl lg:text-5xl font-serif italic leading-tight">Contact</h1>
      <p class="text-ivoir/80 mt-2">Nous sommes à votre écoute</p>
    </div>
  </section>

  <!-- main content -->
  <section class="py-16 lg:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- form column -->
        <div>
          <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="font-serif text-2xl mb-6">Envoyez-nous un message</h2>
            <div id="form-status" class="hidden mb-4 p-4 rounded-lg text-sm"></div>
            <form id="contact-form" class="space-y-6" aria-label="Formulaire de contact">
              <div>
                <label for="nom_complet" class="block text-sm font-medium mb-1">Nom <abbr title="obligatoire">*</abbr></label>
                <input type="text" id="nom_complet" name="nom_complet" required
                  class="w-full bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-1">Email <abbr title="obligatoire">*</abbr></label>
                <input type="email" id="email" name="email" required
                  class="w-full bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" />
              </div>
              <div>
                <label for="telephone" class="block text-sm font-medium mb-1">Téléphone</label>
                <input type="tel" id="telephone" name="telephone"
                  class="w-full bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" />
              </div>
              <div>
                <label for="sujet" class="block text-sm font-medium mb-1">Sujet <abbr title="obligatoire">*</abbr></label>
                <input type="text" id="sujet" name="sujet" required
                  class="w-full bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-1">Message <abbr title="obligatoire">*</abbr></label>
                <textarea id="message" name="message" rows="6" required
                  class="w-full bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none resize-none"></textarea>
              </div>
              <div class="flex items-center">
                <input type="checkbox" id="newsletter" name="newsletter"
                  class="h-4 w-4 text-or-profond focus:ring-or-profond border-ivoir/50 rounded" />
                <label for="newsletter" class="ml-2 text-sm">Je souhaite recevoir la newsletter du festival</label>
              </div>
              <button type="submit"
                class="w-full bg-or-profond text-noir font-bold uppercase text-sm px-6 py-3 rounded-lg hover:bg-doré-clair transition-colors">
                Envoyer le message
              </button>
              <p class="text-xs text-gris-claire"><abbr title="obligatoire">*</abbr> Champs obligatoires</p>
            </form>

            <script>
              document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
                e.preventDefault();
                const form = e.target as HTMLFormElement;
                const statusEl = document.getElementById('form-status')!;
                const formData = new FormData(form);
                const body: Record<string, string> = {};
                formData.forEach((v, k) => { body[k] = v.toString(); });

                try {
                  const res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                  });
                  const json = await res.json();
                  if (res.ok) {
                    statusEl.textContent = json.message || 'Message envoyé !';
                    statusEl.className = 'mb-4 p-4 rounded-lg text-sm bg-green-100 text-green-800';
                    form.reset();
                  } else {
                    statusEl.textContent = json.error || 'Erreur lors de l\'envoi.';
                    statusEl.className = 'mb-4 p-4 rounded-lg text-sm bg-red-100 text-red-800';
                  }
                } catch {
                  statusEl.textContent = 'Impossible de contacter le serveur.';
                  statusEl.className = 'mb-4 p-4 rounded-lg text-sm bg-red-100 text-red-800';
                }
              });
            </script>
          </div>
        </div>

        <!-- info column -->
        <div class="space-y-8">
          <!-- coordinates card -->
          <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="font-serif text-2xl mb-4">Nos coordonnées</h2>
            <div class="space-y-6 text-sm">
              <div class="flex items-start gap-3">
                <Image src={mapIcon} alt="" class="w-6 h-6 shrink-0" aria-hidden="true" />
                <div>
                  <h3 class="font-semibold">Siège du Festival</h3>
                  <address class="not-italic whitespace-pre-line">
                    {address}
                  </address>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Image src={phoneIcon} alt="" class="w-6 h-6 shrink-0" aria-hidden="true" />
                <div>
                  <h3 class="font-semibold">Téléphone</h3>
                  <p>
                    <strong>Standard :</strong> <a href={`tel:${phoneStandard.replace(/\s+/g,'')}`} class="text-or-profond">{phoneStandard}</a><br />
                    <strong>Billetterie :</strong> <a href={`tel:${phoneBilletterie.replace(/\s+/g,'')}`} class="text-or-profond">{phoneBilletterie}</a>
                  </p>
                  <p class="text-xs text-gris-claire">Du lundi au vendredi, 10h‑18h</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Image src={mailIcon} alt="" class="w-6 h-6 shrink-0" aria-hidden="true" />
                <div>
                  <h3 class="font-semibold">Email</h3>
                  <p class="text-sm">
                    <strong>Information générale :</strong><br />
                    <a href={`mailto:${emailGeneral}`} class="text-or-profond">{emailGeneral}</a>
                  </p>
                  <p class="text-sm mt-2">
                    <strong>Billetterie :</strong><br />
                    <a href={`mailto:${emailBilletterie}`} class="text-or-profond">{emailBilletterie}</a>
                  </p>
                  <p class="text-sm mt-2">
                    <strong>Presse :</strong><br />
                    <a href={`mailto:${emailPresse}`} class="text-or-profond">{emailPresse}</a>
                  </p>
                  <p class="text-sm mt-2">
                    <strong>Partenariats :</strong><br />
                    <a href={`mailto:${emailPartenariat}`} class="text-or-profond">{emailPartenariat}</a>
                  </p>
                </div>
              </div>
            </div>
          </div>
          <!-- social card -->
          <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="font-serif text-2xl mb-4">Suivez-nous</h2>
            <div class="flex items-center gap-4">
              <a href="#" aria-label="Facebook"><Image src={facebookIcon} alt="" class="w-6 h-6" /></a>
              <a href="#" aria-label="Twitter"><Image src={twitterIcon} alt="" class="w-6 h-6" /></a>
              <a href="#" aria-label="Instagram"><Image src={instagramIcon} alt="" class="w-6 h-6" /></a>
              <a href="#" aria-label="YouTube"><Image src={youtubeIcon} alt="" class="w-6 h-6" /></a>
            </div>
          </div>
          <!-- hours card -->
          <div class="bg-white rounded-xl shadow-sm p-8">
            <h2 class="font-serif text-2xl mb-4">Horaires d'ouverture</h2>
            <table class="w-full text-sm">
              <tbody>
                <tr>
                  <td>Lundi - Samedi</td>
                  <td class="text-right">10h00 - 19h00</td>
                </tr>
                <tr>
                  <td>Dimanche</td>
                  <td class="text-right">Fermé</td>
                </tr>
                <tr>
                  <td>Jours de concert</td>
                  <td class="text-right">Jusqu'à 22h00</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>