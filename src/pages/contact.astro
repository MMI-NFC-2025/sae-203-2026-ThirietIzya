---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Chorus Symphonia 2025">
  
  <section class="relative h-[45vh] flex items-center justify-center text-center text-ivoir overflow-hidden bg-noir">
    <div class="absolute inset-0 z-0">
      <img src="/assets/img/hero_accueil.webp" alt="Contact Chorus Symphonia" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative z-10 px-6">
      <p class="text-or-profond uppercase tracking-[0.4em] mb-4 text-xs font-bold">Contact</p>
      <h1 class="text-4xl lg:text-6xl font-serif italic leading-tight">Nous sommes à votre écoute</h1>
    </div>
  </section>

  <section class="bg-ivoir pt-16 lg:pt-24 text-center px-6">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl lg:text-4xl italic mb-6 text-noir">Contactez-nous</h2>
      <p class="text-gris-claire font-light leading-relaxed">
        Une question ? Une demande de partenariat ou de réservation ? <br class="hidden md:block"/>
        N'hésitez pas à nous contacter via le formulaire ou nos coordonnées.
      </p>
    </div>
  </section>

  <section class="bg-ivoir py-16 lg:py-24">
    <div class="grille gap-y-16 items-start">
      
      <div class="lg:col-span-7 bg-white p-8 lg:p-12 border border-noir/5 shadow-sm">
        <h3 class="font-serif text-2xl italic mb-10 text-noir">Envoyez-nous un message</h3>
        
        <form class="flex flex-col gap-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label for="name" class="text-[10px] uppercase font-bold tracking-widest text-gris-claire">Nom complet *</label>
              <input type="text" id="name" name="name" required class="bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" placeholder="Jean Dupont" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="text-[10px] uppercase font-bold tracking-widest text-gris-claire">Email *</label>
              <input type="email" id="email" name="email" required class="bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none" placeholder="votre@email.com" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="subject" class="text-[10px] uppercase font-bold tracking-widest text-gris-claire">Sujet *</label>
            <select id="subject" name="subject" class="bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none cursor-pointer appearance-none">
              <option value="billetterie">Billetterie & Réservations</option>
              <option value="programme">Programme du Festival</option>
              <option value="partenariat">Devenir Partenaire</option>
              <option value="autre">Autre demande</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-[10px] uppercase font-bold tracking-widest text-gris-claire">Message *</label>
            <textarea id="message" name="message" rows="6" required class="bg-ivoir/20 border border-ivoir/50 px-4 py-3 text-sm focus:outline-none focus:border-or-profond transition-colors outline-none resize-none" placeholder="Comment pouvons-nous vous aider ?"></textarea>
          </div>

          <div class="flex items-center gap-3 py-2">
            <input type="checkbox" id="newsletter" class="w-4 h-4 accent-or-profond cursor-pointer" />
            <label for="newsletter" class="text-xs text-gris-claire cursor-pointer">Je souhaite recevoir la newsletter du festival</label>
          </div>

          <button type="submit" class="bg-or-profond text-noir px-10 py-4 text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-noir hover:text-ivoir transition-all duration-300 w-full md:w-fit self-center md:self-start shadow-md">
            Envoyer le message
          </button>
          
          <p class="text-[10px] text-center md:text-left opacity-40 mt-2">* Champs obligatoires</p>
        </form>
      </div>

      <div class="lg:col-span-5 flex flex-col gap-8">
        
        <div class="bg-white p-8 lg:p-10 border border-noir/5 shadow-sm">
          <h3 class="font-serif text-xl italic mb-8 text-noir">Coordonnées</h3>
          <div class="flex flex-col gap-8">
            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-ivoir rounded-full flex items-center justify-center text-or-profond shrink-0 border border-or-profond/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <p class="text-[10px] uppercase font-bold tracking-widest text-or-profond mb-1">Téléphone</p>
                <p class="text-sm font-medium">+33 1 42 33 44 55</p>
                <p class="text-xs text-gris-claire italic">Lun-Sam : 10h - 19h</p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-ivoir rounded-full flex items-center justify-center text-or-profond shrink-0 border border-or-profond/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="text-[10px] uppercase font-bold tracking-widest text-or-profond mb-1">Email</p>
                <a href="mailto:contact@chorussymphonia.fr" class="text-sm font-medium hover:text-or-profond transition-colors">contact@chorussymphonia.fr</a>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-12 h-12 bg-ivoir rounded-full flex items-center justify-center text-or-profond shrink-0 border border-or-profond/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <p class="text-[10px] uppercase font-bold tracking-widest text-or-profond mb-1">Adresse</p>
                <p class="text-sm font-medium leading-relaxed">Opéra National de Paris<br/>8 Rue Scribe, 75009 Paris</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 lg:p-10 border border-noir/5 shadow-sm text-center lg:text-left">
          <h3 class="font-serif text-xl italic mb-6 text-noir">Suivez-nous</h3>
          <div class="flex justify-center lg:justify-start gap-6">
            <a href="#" class="w-10 h-10 rounded-full border border-ivoir flex items-center justify-center text-noir hover:bg-or-profond hover:border-or-profond transition-all group">
               <span class="sr-only">Facebook</span>
               <div class="w-2 h-2 bg-current opacity-70"></div>
            </a>
            <a href="#" class="w-10 h-10 rounded-full border border-ivoir flex items-center justify-center text-noir hover:bg-or-profond hover:border-or-profond transition-all group">
               <span class="sr-only">Instagram</span>
               <div class="w-2 h-2 bg-current opacity-70"></div>
            </a>
            <a href="#" class="w-10 h-10 rounded-full border border-ivoir flex items-center justify-center text-noir hover:bg-or-profond hover:border-or-profond transition-all group">
               <span class="sr-only">YouTube</span>
               <div class="w-2 h-2 bg-current opacity-70"></div>
            </a>
          </div>
        </div>

        <div class="bg-noir text-ivoir p-8 lg:p-10 border-l-4 border-or-profond shadow-2xl">
          <h3 class="font-serif text-xl italic mb-8 text-or-profond">Horaires d'ouverture</h3>
          <ul class="space-y-4 text-sm font-light">
            <li class="flex justify-between border-b border-ivoir/10 pb-2"><span>Lundi — Samedi</span> <span class="font-medium">10h00 — 19h00</span></li>
            <li class="flex justify-between border-b border-ivoir/10 pb-2 text-ivoir/40"><span>Dimanche</span> <span>Fermé</span></li>
            <li class="flex justify-between text-or-profond pt-2"><span>Jours de concert</span> <span class="font-bold tracking-widest uppercase text-xs">Jusqu'à 22h00</span></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

</Layout>