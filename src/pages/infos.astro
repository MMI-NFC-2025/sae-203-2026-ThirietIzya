---
import Layout from '../layouts/Layout.astro';

const transportData = [
  {
    venue: "Opéra National de Paris",
    address: "Place de l'Opéra, 75009 Paris",
    access: "Métro : Opéra (3, 7, 8) | RER A : Auber"
  },
  {
    venue: "Théâtre des Champs-Élysées",
    address: "15 Avenue Montaigne, 75008 Paris",
    access: "Métro : Alma-Marceau (9) | RER C : Pont de l'Alma"
  },
  {
    venue: "Salle Pleyel",
    address: "252 Rue du Faubourg Saint-Honoré, 75008 Paris",
    access: "Métro : Ternes (2) | RER A : CDG-Étoile"
  }
];
---

<Layout title="Informations Pratiques | Chorus Symphonia">

  <section class="relative h-[50vh] w-full flex items-center justify-center text-center text-ivoir overflow-hidden bg-noir">
    <div class="absolute inset-0 z-0">
      <img src="/assets/img/salle_des_glaces.webp" alt="Billetterie" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative z-10 px-6">
      <p class="text-or-profond uppercase tracking-[0.4em] mb-4 text-xs font-bold">Votre Visite</p>
      <h1 class="text-3xl lg:text-6xl font-serif italic leading-tight">Informations Pratiques</h1>
    </div>
  </section>

  <section class="bg-ivoir py-16 lg:py-24 w-full">
    <div class="grille gap-y-12">
      
      <div class="lg:col-span-6 bg-white p-8 lg:p-12 shadow-sm border border-noir/5">
        <h2 class="font-serif text-3xl italic mb-10 text-noir border-b border-or-profond/20 pb-4">Billetterie</h2>
        <ul class="space-y-4 text-sm font-light text-gris-claire">
          <li class="flex justify-between border-b border-ivoir pb-2"><span>Plein tarif</span> <strong class="text-noir">65€ — 120€</strong></li>
          <li class="flex justify-between border-b border-ivoir pb-2"><span>Tarif réduit</span> <strong class="text-noir">35€ — 80€</strong></li>
          <li class="flex justify-between"><span>Pass Festival (8 soirées)</span> <strong class="text-or-profond font-bold text-lg">380€</strong></li>
        </ul>
        <div class="mt-10 p-4 bg-ivoir/30 border border-or-profond/10">
          <p class="text-[10px] uppercase font-bold tracking-widest text-or-profond mb-2">Points de vente</p>
          <p class="text-xs leading-relaxed opacity-70">En ligne (24h/24), par téléphone au 01 42 33 44 55 ou aux guichets des salles.</p>
        </div>
      </div>

      <div class="lg:col-span-6 bg-white p-8 lg:p-12 shadow-sm border border-noir/5 flex flex-col justify-between">
        <div>
          <h2 class="font-serif text-3xl italic mb-10 text-noir border-b border-or-profond/20 pb-4">Dates & Horaires</h2>
          <p class="text-or-profond font-bold text-lg mb-4">Du 15 au 22 Juin 2025</p>
          <p class="text-sm font-light leading-relaxed text-gris-claire mb-8 italic">
            Tous les concerts commencent à 20h00. L'ouverture des portes s'effectue 45 minutes avant le début.
          </p>
          <div class="bg-noir text-ivoir p-6 border-l-4 border-or-profond text-xs leading-relaxed uppercase tracking-tighter opacity-90">
            Les portes ferment 5 minutes avant le début. Retardataires admis uniquement à l'entracte.
          </div>
        </div>
        <a href="/programme" class="mt-12 bg-or-profond text-noir py-4 text-center text-[10px] font-bold uppercase tracking-widest hover:bg-noir hover:text-ivoir transition-all">
          Découvrir le programme complet
        </a>
      </div>

    </div>
  </section>

  <section class="bg-white py-20 lg:py-32 border-y border-noir/5 w-full">
    <div class="grille">
        <h2 class="lg:col-span-12 font-serif text-3xl lg:text-4xl italic text-center mb-20 text-noir">Accès aux Salles</h2>
        
        {transportData.map((item) => (
          <div class="lg:col-span-4 flex flex-col gap-6 group mb-12 lg:mb-0">
            <div class="w-12 h-[1px] bg-or-profond group-hover:w-full transition-all duration-700"></div>
            <h3 class="font-serif text-2xl italic group-hover:text-or-profond transition-colors">{item.venue}</h3>
            <div class="space-y-4 text-sm font-light text-gris-claire">
              <p><strong class="block text-[10px] uppercase tracking-widest text-noir opacity-40 mb-1">Adresse</strong> {item.address}</p>
              <p><strong class="block text-[10px] uppercase tracking-widest text-noir opacity-40 mb-1">Accès</strong> {item.access}</p>
            </div>
          </div>
        ))}
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32 w-full">
    <div class="grille items-start gap-y-16">
      
      <div class="lg:col-span-7">
        <h2 class="font-serif text-3xl italic mb-12 text-noir">Foire aux questions</h2>
        <div class="space-y-4">
          <details class="group bg-white border border-noir/5 p-6 cursor-pointer">
            <summary class="list-none flex justify-between items-center font-bold text-xs uppercase tracking-widest">
              Comment réserver ?
              <span class="text-or-profond group-open:rotate-45 transition-transform text-2xl">+</span>
            </summary>
            <p class="mt-6 text-sm font-light text-gris-claire border-t border-ivoir pt-4 italic">
              Via notre site web 24h/24 ou par téléphone au +33 1 23 45 67 89.
            </p>
          </details>
          <details class="group bg-white border border-noir/5 p-6 cursor-pointer">
            <summary class="list-none flex justify-between items-center font-bold text-xs uppercase tracking-widest">
              Vestiaire et objets encombrants ?
              <span class="text-or-profond group-open:rotate-45 transition-transform text-2xl">+</span>
            </summary>
            <p class="mt-6 text-sm font-light text-gris-claire border-t border-ivoir pt-4 italic">
              Un vestiaire gratuit est disponible. Les bagages volumineux ne sont pas admis.
            </p>
          </details>
        </div>
      </div>

      <div class="lg:col-span-5 bg-noir text-ivoir p-10 lg:p-16 shadow-2xl flex flex-col gap-10">
        <h2 class="font-serif text-3xl italic text-or-profond">Services</h2>
        <ul class="space-y-8 text-sm font-light">
          <li class="flex gap-4"><span class="text-or-profond font-bold">01.</span> Vestiaire gratuit surveillé.</li>
          <li class="flex gap-4"><span class="text-or-profond font-bold">02.</span> Salles accessibles PMR.</li>
          <li class="flex gap-4"><span class="text-or-profond font-bold">03.</span> Bar et restauration sur place.</li>
        </ul>
      </div>

    </div>
  </section>

</Layout>

<style>
  summary::-webkit-details-marker { display: none; }
</style>