---
import Layout from '../layouts/Layout.astro';
import {Image} from 'astro:assets';

// main hero image
import heroImage from '../assets/img/hero_accueil.webp';

// partner logos (used in Nos Partenaires section)
import villeDeParisLogo from '../assets/img/ville_de_paris.webp';
import gouvernementLogo from '../assets/img/gouvernement.webp';
import sacemLogo from '../assets/img/sacem.webp';
import orangeLogo from '../assets/img/orange.webp';

// additional partner images
import lvmhLogo from '../assets/img/lvmh.webp';
import leFigaroLogo from '../assets/img/le_figaro.webp';
import classicaLogo from '../assets/img/classica.webp';
import radioClassiqueLogo from '../assets/img/radio_classique.webp';

// SVG icons used across the page
import calendrierIcon from '../assets/icon/calendrier_dore.svg';
import mapIcon from '../assets/icon/map_dore.svg';
import telechargementIcon from '../assets/icon/telechargement.svg';

// icons for feature cards
import musiqueIcon from '../assets/icon/musique_dore.svg';
import equipeIcon from '../assets/icon/equipe_dore.svg';
import batimentIcon from '../assets/icon/batiment_dore.svg';
---

<Layout title="Chorus Symphonia 2025 | Festival de Musique Classique">
  
  <section class="relative h-screen flex items-center justify-center text-center text-ivoir overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image src={heroImage} alt="Orchestre" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-noir/60"></div>
    </div>

    <div class="relative z-10 px-6 max-w-4xl">
      <p class="text-or-profond uppercase tracking-[0.4em] mb-6 text-sm font-medium">
        Chorus Symphonia 2025
      </p>
      <h1 class="mb-8 text-ivoir text-4xl lg:text-6xl font-serif italic leading-tight">
        Une célébration exceptionnelle de la musique classique
      </h1>
      
      <div class="flex flex-col items-center gap-4 mb-12 text-ivoir/90 text-sm tracking-widest uppercase">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-or-profond" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          15 - 22 Juin 2025
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-or-profond" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          Opéra National, Paris
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <a href="/billetterie" class="bg-or-profond text-noir px-10 py-4 font-bold uppercase tracking-[0.2em] text-xs hover:bg-doré-clair transition-all shadow-xl">
          Réserver vos billets
        </a>
        <a href="/programme" class="border border-ivoir text-ivoir px-10 py-4 font-bold uppercase tracking-[0.2em] text-xs hover:bg-ivoir hover:text-noir transition-all">
          Le Programme
        </a>
      </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 14l-7 7-7-7"></path></svg>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32 text-noir">
    <div class="max-w-300 mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="font-serif text-3xl lg:text-5xl mb-4 italic">Découvrez le Festival</h2>
        <p class="text-gris-claire uppercase tracking-widest text-xs">Explorez toutes les facettes de Chorus Symphonia 2025</p>
        <div class="w-20 h-px bg-or-profond mx-auto mt-8"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <!-- Programme card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-center text-center shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={musiqueIcon} alt="Icône musique" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Programme</h3>
          <p class="text-sm text-gris-claire leading-relaxed mb-6">8 soirées exceptionnelles avec les plus grands chefs-d'œuvre.</p>
          <a href="/programme" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
        </article>

        <!-- Artistes card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-center text-center shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={equipeIcon} alt="Icône artistes" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Artistes</h3>
          <p class="text-sm text-gris-claire leading-relaxed mb-6">Découvrez les artistes de renommée internationale.</p>
          <a href="/artistes" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
        </article>

        <!-- Scènes card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-center text-center shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={batimentIcon} alt="Icône scènes" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Scènes</h3>
          <p class="text-sm text-gris-claire leading-relaxed mb-6">3 salles prestigieuses au cœur de Paris.</p>
          <a href="/scenes" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
        </article>

        <!-- Festival card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-center text-center shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={calendrierIcon} alt="Icône festival" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Le Festival</h3>
          <p class="text-sm text-gris-claire leading-relaxed mb-6">27 ans de passion pour la musique classique.</p>
          <a href="/festival" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
        </article>

      </div>
    </div>
  </section>

  <!-- informations pratiques cards -->
  <section class="bg-ivoir py-20 lg:py-32 text-noir">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-3xl italic mb-12 text-center">Informations Pratiques</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Dates card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-start text-left shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={calendrierIcon} alt="Calendrier" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Dates</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm mb-4">15‑22 Juin 2025</p>
          <a href="/infos" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/40 pb-1 hover:border-or-profond transition-all">Voir plus →</a>
        </article>

        <!-- Lieu card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-start text-left shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={mapIcon} alt="Lieu" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Lieu</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm mb-4">Opéra National, Paris</p>
          <a href="/infos" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/40 pb-1 hover:border-or-profond transition-all">Accès →</a>
        </article>

        <!-- Billetterie card -->
        <article class="bg-white rounded-xl p-8 flex flex-col items-start text-left shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="bg-or-profond/10 p-4 rounded-lg mb-4">
            <Image src={telechargementIcon} alt="Billetterie" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-xl mb-2">Billetterie</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm mb-4">À partir de 35€</p>
          <a href="/billetterie" class="bg-or-profond text-noir px-8 py-3 text-xs font-bold uppercase tracking-widest hover:bg-noir hover:text-ivoir transition-all">Réserver</a>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32">
    <div class="max-w-250 mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl italic mb-4">Nos Partenaires</h2>
      <p class="text-gris-claire text-sm mb-12 font-light">Ils nous font confiance et contribuent au succès du festival</p>

      <!-- Institutionnels -->
      <h3 class="font-serif text-xl mb-4">Partenaires Institutionnels</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12 justify-center">
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={villeDeParisLogo} alt="Ville de Paris" class="h-12 w-auto" />
        </article>
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={gouvernementLogo} alt="Île-de-France" class="h-12 w-auto" />
        </article>
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={sacemLogo} alt="SACEM" class="h-10 w-auto" />
        </article>
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={orangeLogo} alt="Orange" class="h-8 w-auto" />
        </article>
      </div>

      <!-- Mécènes -->
      <h3 class="font-serif text-xl mb-4">Mécènes</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 justify-center">
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-2xl">
          <Image src={lvmhLogo} alt="LVMH" class="h-12 w-auto" />
        </article>
      </div>

      <!-- Médias -->
      <h3 class="font-serif text-xl mb-4">Partenaires Médias</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 mb-12 justify-center">
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={leFigaroLogo} alt="Le Figaro" class="h-10 w-auto" />
        </article>
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={classicaLogo} alt="Classica" class="h-10 w-auto" />
        </article>
        <article class="bg-white rounded-xl p-8 flex items-center justify-center border border-noir/5 max-w-xs">
          <Image src={radioClassiqueLogo} alt="Radio Classique" class="h-10 w-auto" />
        </article>
      </div>

      <div class="mt-20">
        <p class="text-gris-claire text-sm mb-6 font-light">Vous souhaitez devenir partenaire ?</p>
        <a href="/contact" class="text-xs font-bold border border-noir/20 px-8 py-3 uppercase tracking-widest hover:bg-noir hover:text-ivoir transition-all">Contactez-nous</a>
      </div>
    </div>
  </section>

</Layout>