---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "Programme",
    description: "8 soirées exceptionnelles avec les plus grands chefs-d'oeuvre",
    href: "/programme",
    icon: "calendar"
  },
  {
    title: "Artistes",
    description: "Découvrez les artistes de renommée internationale",
    href: "/artistes",
    icon: "users"
  },
  {
    title: "Scènes",
    description: "3 salles prestigieuses au coeur de Paris",
    href: "/scenes",
    icon: "building"
  },
  {
    title: "Le Festival",
    description: "27 ans de passion pour la musique classique",
    href: "/festival",
    icon: "music"
  }
];

const infos = [
  {
    title: "Dates",
    value: "15-22 Juin 2025",
    link: { href: "/programme", label: "Voir plus" }
  },
  {
    title: "Lieu",
    value: "Opéra National, Paris",
    link: { href: "/scenes", label: "Accès" }
  },
  {
    title: "Billetterie",
    value: "À partir de 35€",
    link: { href: "#billetterie", label: "Réserver" }
  }
];

const partners = {
  institutionnels: ["Ministère de la Culture", "Ville de Paris", "Région Île-de-France"],
  mecenes: ["Fondation Total", "BNP Paribas", "LVMH"],
  medias: ["France Musique", "Arte", "Le Figaro"]
};
---

<Layout>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-b from-primary via-primary-light to-primary"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-gold/10 via-transparent to-transparent"></div>
    
    <!-- Decorative elements -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-gold/5 rounded-full blur-3xl"></div>
    
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Festival de Musique Classique</p>
      <h1 class="text-white mb-6">
        Chorus Symphonia <span class="gold-gradient">2025</span>
      </h1>
      <p class="text-xl md:text-2xl text-white/70 mb-8 font-light">
        Une célébration exceptionnelle de la musique classique
      </p>
      
      <div class="flex flex-wrap justify-center gap-6 mb-12">
        <div class="flex items-center gap-2 text-white/80">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span>15-22 Juin 2025</span>
        </div>
        <div class="flex items-center gap-2 text-white/80">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Opéra National, Paris</span>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#billetterie" class="btn-primary text-base px-8 py-4">
          Réserver vos billets
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/programme" class="btn-secondary text-base px-8 py-4">
          Découvrir le programme
        </a>
      </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- Découvrez le Festival -->
  <section class="py-20 md:py-32 bg-primary">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-title">
        <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Explorer</p>
        <h2 class="text-white">Découvrez le Festival</h2>
        <p class="text-white/60 mt-4 max-w-2xl mx-auto">
          Explorez toutes les facettes de Chorus Symphonia 2025
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map(feature => (
          <a href={feature.href} class="card group hover:-translate-y-1">
            <div class="w-12 h-12 rounded-xl bg-gold/10 flex items-center justify-center mb-4 group-hover:bg-gold/20 transition-colors">
              {feature.icon === 'calendar' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              )}
              {feature.icon === 'users' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
                </svg>
              )}
              {feature.icon === 'building' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              )}
              {feature.icon === 'music' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                </svg>
              )}
            </div>
            <h3 class="text-white mb-2">{feature.title}</h3>
            <p class="text-white/60 text-sm mb-4">{feature.description}</p>
            <span class="text-gold text-sm font-medium flex items-center gap-2 group-hover:gap-3 transition-all">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Informations Pratiques -->
  <section id="infos" class="py-20 md:py-32 bg-primary-light">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-title">
        <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Pratique</p>
        <h2 class="text-white">Informations Pratiques</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {infos.map(info => (
          <div class="card text-center">
            <h3 class="text-gold mb-2">{info.title}</h3>
            <p class="text-white text-xl font-semibold mb-4">{info.value}</p>
            <a href={info.link.href} class="text-white/60 hover:text-gold text-sm transition-colors inline-flex items-center gap-2">
              {info.link.label}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Billetterie -->
  <section id="billetterie" class="py-20 md:py-32 bg-primary">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="card p-8 md:p-12 bg-gradient-to-br from-primary-light to-primary border-gold/20">
        <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Billetterie</p>
        <h2 class="text-white mb-4">Réservez vos places</h2>
        <p class="text-white/60 mb-8 max-w-2xl mx-auto">
          Ne manquez pas cette édition exceptionnelle du Festival Chorus Symphonia. 
          Réservez dès maintenant vos billets pour les concerts de votre choix.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/programme" class="btn-primary text-base px-8 py-4">
            Voir le programme complet
          </a>
          <a href="#" class="btn-secondary text-base px-8 py-4">
            Acheter un pass festival
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Partenaires -->
  <section id="partenaires" class="py-20 md:py-32 bg-primary-light">
    <div class="max-w-7xl mx-auto px-6">
      <div class="section-title">
        <p class="text-gold font-medium tracking-widest uppercase mb-4 text-sm">Partenaires</p>
        <h2 class="text-white">Nos Partenaires</h2>
        <p class="text-white/60 mt-4 max-w-2xl mx-auto">
          Ils nous font confiance et contribuent au succès du festival
        </p>
      </div>
      
      <div class="space-y-12">
        <!-- Partenaires Institutionnels -->
        <div>
          <h3 class="text-white/60 text-center mb-6 text-sm uppercase tracking-wider">Partenaires Institutionnels</h3>
          <div class="flex flex-wrap justify-center gap-8">
            {partners.institutionnels.map(partner => (
              <div class="px-6 py-4 bg-white/5 rounded-lg border border-white/10">
                <span class="text-white/80 font-medium">{partner}</span>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Mécènes -->
        <div>
          <h3 class="text-white/60 text-center mb-6 text-sm uppercase tracking-wider">Mécènes</h3>
          <div class="flex flex-wrap justify-center gap-8">
            {partners.mecenes.map(partner => (
              <div class="px-6 py-4 bg-white/5 rounded-lg border border-white/10">
                <span class="text-white/80 font-medium">{partner}</span>
              </div>
            ))}
          </div>
        </div>
        
        <!-- Partenaires Médias -->
        <div>
          <h3 class="text-white/60 text-center mb-6 text-sm uppercase tracking-wider">Partenaires Médias</h3>
          <div class="flex flex-wrap justify-center gap-8">
            {partners.medias.map(partner => (
              <div class="px-6 py-4 bg-white/5 rounded-lg border border-white/10">
                <span class="text-white/80 font-medium">{partner}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      
      <div class="text-center mt-12">
        <p class="text-white/60 mb-4">Vous souhaitez devenir partenaire ?</p>
        <a href="mailto:partenariat@chorussymphonia.fr" class="btn-secondary">
          Contactez-nous
        </a>
      </div>
    </div>
  </section>
</Layout>
