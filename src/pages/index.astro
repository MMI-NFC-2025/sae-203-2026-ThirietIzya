---
import Layout from '../layouts/Layout.astro';
import {Image} from 'astro:assets';
import heroImage from '../assets/img/hero_accueil.webp';
---

<Layout title="Chorus Symphonia 2025 | Festival de Musique Classique">
  
  <section class="relative h-screen flex items-center justify-center text-center text-ivoir overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image src={heroImage} alt="Orchestre" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-noir/60"></div>
    </div>

    <div class="relative z-10 px-6 max-w-4xl">
      <p class="text-or-profond uppercase tracking-[0.4em] mb-6 text-sm font-medium">
        Chorus Symphonia 2025
      </p>
      <h1 class="mb-8 text-ivoir text-4xl lg:text-6xl font-serif italic leading-tight">
        Une célébration exceptionnelle de la musique classique
      </h1>
      
      <div class="flex flex-col items-center gap-4 mb-12 text-ivoir/90 text-sm tracking-widest uppercase">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-or-profond" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          15 - 22 Juin 2025
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-or-profond" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          Opéra National, Paris
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <a href="/billetterie" class="bg-or-profond text-noir px-10 py-4 font-bold uppercase tracking-[0.2em] text-xs hover:bg-doré-clair transition-all shadow-xl">
          Réserver vos billets
        </a>
        <a href="/programme" class="border border-ivoir text-ivoir px-10 py-4 font-bold uppercase tracking-[0.2em] text-xs hover:bg-ivoir hover:text-noir transition-all">
          Le Programme
        </a>
      </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 14l-7 7-7-7"></path></svg>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32 text-noir">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="font-serif text-3xl lg:text-5xl mb-4 italic">Découvrez le Festival</h2>
        <p class="text-gris-claire uppercase tracking-widest text-xs">Explorez toutes les facettes de Chorus Symphonia 2025</p>
        <div class="w-20 h-[1px] bg-or-profond mx-auto mt-8"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        
        <article class="group bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="h-56 overflow-hidden relative">
            <img src="/assets/img/programme_thumb.webp" alt="Programme" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-noir/20"></div>
            <h3 class="absolute bottom-4 left-4 text-ivoir font-serif text-xl">Programme</h3>
          </div>
          <div class="p-6">
            <p class="text-sm text-gris-claire leading-relaxed mb-6">8 soirées exceptionnelles avec les plus grands chefs-d'œuvre.</p>
            <a href="/programme" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
          </div>
        </article>

        <article class="group bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="h-56 overflow-hidden relative">
            <img src="/assets/img/artistes_thumb.webp" alt="Artistes" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-noir/20"></div>
            <h3 class="absolute bottom-4 left-4 text-ivoir font-serif text-xl">Artistes</h3>
          </div>
          <div class="p-6">
            <p class="text-sm text-gris-claire leading-relaxed mb-6">Découvrez les artistes de renommée internationale.</p>
            <a href="/artistes" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
          </div>
        </article>

        <article class="group bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="h-56 overflow-hidden relative">
            <img src="/assets/img/scenes_thumb.webp" alt="Scènes" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-noir/20"></div>
            <h3 class="absolute bottom-4 left-4 text-ivoir font-serif text-xl">Scènes</h3>
          </div>
          <div class="p-6">
            <p class="text-sm text-gris-claire leading-relaxed mb-6">3 salles prestigieuses au cœur de Paris.</p>
            <a href="/scenes" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
          </div>
        </article>

        <article class="group bg-white overflow-hidden shadow-sm hover:shadow-xl transition-all border border-noir/5">
          <div class="h-56 overflow-hidden relative">
            <img src="/assets/img/festival_thumb.webp" alt="Le Festival" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-noir/20"></div>
            <h3 class="absolute bottom-4 left-4 text-ivoir font-serif text-xl">Le Festival</h3>
          </div>
          <div class="p-6">
            <p class="text-sm text-gris-claire leading-relaxed mb-6">27 ans de passion pour la musique classique.</p>
            <a href="/festival" class="text-or-profond uppercase tracking-widest text-[10px] font-bold border-b border-or-profond/30 pb-1 hover:border-or-profond transition-all">En savoir plus →</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- informations pratiques icons section -->
  <section class="bg-ivoir py-20 lg:py-32 text-noir">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl italic mb-12">Informations Pratiques</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="flex flex-col items-center gap-4">
          <img src="/assets/icon/calendrier_dore.svg" alt="Calendrier" class="w-12 h-12" />
          <h3 class="font-serif text-xl">Dates</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">15‑22 Juin 2025</p>
          <a href="/infos" class="text-[10px] font-bold border-b border-or-profond/40 uppercase tracking-widest">Voir plus</a>
        </div>
        <div class="flex flex-col items-center gap-4">
          <img src="/assets/icon/map_dore.svg" alt="Lieu" class="w-12 h-12" />
          <h3 class="font-serif text-xl">Lieu</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">Opéra National, Paris</p>
          <a href="/infos" class="text-[10px] font-bold border-b border-or-profond/40 uppercase tracking-widest">Accès</a>
        </div>
        <div class="flex flex-col items-center gap-4">
          <img src="/assets/icon/telechargement.svg" alt="Billetterie" class="w-12 h-12" />
          <h3 class="font-serif text-xl">Billetterie</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">À partir de 35€</p>
          <a href="/billetterie" class="bg-or-profond text-noir px-8 py-3 text-xs font-bold uppercase tracking-widest mt-4">Réserver</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-20 border-y border-noir/5">
    <div class="max-w-4xl mx-auto px-6">
      <div class="flex flex-col gap-16">
        
        <div class="flex flex-col items-center text-center gap-4">
          <div class="p-4 border border-or-profond/20 rounded-full">
            <img src="/assets/icon/calendrier_dore.svg" alt="Calendrier" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-2xl italic">Dates</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">15-22 Juin 2025</p>
          <a href="/infos" class="text-[10px] font-bold border-b border-or-profond/40 uppercase tracking-widest">Voir plus</a>
        </div>

        <div class="h-[1px] w-full bg-or-profond/10"></div>

        <div class="flex flex-col items-center text-center gap-4">
          <div class="p-4 border border-or-profond/20 rounded-full">
            <img src="/assets/icon/map_dore.svg" alt="Lieu" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-2xl italic">Lieu</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">Opéra National, Paris</p>
          <a href="/infos" class="text-[10px] font-bold border-b border-or-profond/40 uppercase tracking-widest">Accès</a>
        </div>

        <div class="h-[1px] w-full bg-or-profond/10"></div>

        <div class="flex flex-col items-center text-center gap-4">
          <div class="p-4 border border-or-profond/20 rounded-full">
            <img src="/assets/icon/telechargement.svg" alt="Billetterie" class="w-8 h-8" />
          </div>
          <h3 class="font-serif text-2xl italic">Billetterie</h3>
          <p class="text-gris-claire tracking-widest font-medium uppercase text-sm">À partir de 35€</p>
          <a href="/billetterie" class="bg-or-profond text-noir px-8 py-3 text-xs font-bold uppercase tracking-widest mt-4">Réserver</a>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-ivoir py-20 lg:py-32">
    <div class="max-w-[1000px] mx-auto px-6 text-center">
      <h2 class="font-serif text-3xl italic mb-12">Nos Partenaires</h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-12 items-center opacity-70">
        <img src="/assets/img/ville_de_paris.webp" alt="Ville de Paris" class="h-12 w-auto mx-auto grayscale hover:grayscale-0 transition-all" />
        <img src="/assets/img/gouvernement.webp" alt="Île-de-France" class="h-12 w-auto mx-auto grayscale hover:grayscale-0 transition-all" />
        <img src="/assets/img/sacem.webp" alt="SACEM" class="h-10 w-auto mx-auto grayscale hover:grayscale-0 transition-all" />
        <img src="/assets/img/orange.webp" alt="Orange" class="h-8 w-auto mx-auto grayscale hover:grayscale-0 transition-all" />
      </div>

      <div class="mt-20">
        <p class="text-gris-claire text-sm mb-6 font-light">Vous souhaitez devenir partenaire ?</p>
        <a href="/contact" class="text-xs font-bold border border-noir/20 px-8 py-3 uppercase tracking-widest hover:bg-noir hover:text-ivoir transition-all">Contactez-nous</a>
      </div>
    </div>
  </section>

</Layout>